<section id="scroll-narrative" class="narrative">
  <div class="narrative__container">
    <p id="narrative-text" class="narrative__text">
      Artemis II será la primera misión tripulada que orbite la Luna en más de
      50 años. Cuatro astronautas viajarán a bordo de la nave Orion, impulsados
      por el cohete más poderoso jamás construido, el Space Launch System. Una
      nueva era de exploración espacial comienza aquí.
    </p>
  </div>
</section>

<style>
  .narrative {
    position: relative;
    z-index: 20;
    min-height: 200vh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 0 2rem;
  }

  .narrative__container {
    position: sticky;
    top: 0%;
    transform: translateY(10%);
    width: 100%;
    padding: 0 10%;
  }

  .narrative__text {
    font-family: "Poppins", sans-serif;
    font-size: clamp(1.6rem, 4vw, 3rem);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0;
    text-shadow: none;
  }

  .narrative__text :global(.word) {
    color: rgba(255, 255, 255, 0.15);
    transition: color 0.1s ease;
    display: inline-block;
    margin-right: 0.3em;
  }

  .narrative__text :global(.word.is-lit) {
    color: #ffffff;
  }

  @media (max-width: 768px) {
    .narrative {
      padding: 0 0;
      min-height: 180vh;
    }
    .narrative__container {
      max-width: 100%;
    }
    .narrative__text {
      font-size: clamp(1.2rem, 5vw, 1.8rem);
    }
  }
</style>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initScrollNarrative() {
    const textEl = document.getElementById("narrative-text");
    const section = document.getElementById("scroll-narrative");
    if (!textEl || !section) return;

    const originalText = textEl.textContent?.trim() || "";
    const words = originalText.split(/\s+/);

    textEl.innerHTML = words
      .map((word, i) => `<span class="word" data-index="${i}">${word}</span>`)
      .join("");

    const wordEls = textEl.querySelectorAll<HTMLSpanElement>(".word");

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top bottom",
        end: "top 20%",
        scrub: 0.5,
        markers: false,
      },
    });

    tl.to(wordEls, {
      color: "#ffffff",
      opacity: 1,
      duration: 1,
      stagger: 1,
      ease: "none",
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initScrollNarrative);
  } else {
    requestAnimationFrame(initScrollNarrative);
  }
</script>
