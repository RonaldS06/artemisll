---
import { Image } from "astro:assets";
import orion_capsule from "../assets/orion_capsule.png";
import astronauta from "../assets/astronauta.png";
---

<section id="closing-trigger" class="closing-section"></section>

<div id="closing-visuals" class="closing-visuals">
  <div class="layer layer-moon" id="layer-moon">
    <div id="moon-container" class="moon-canvas-container"></div>
  </div>

  <div class="layer layer-badge" id="layer-badge">
    <span class="cta-badge">2026</span>
  </div>

  <div class="layer layer-orion" id="layer-orion">
    <Image
      src={orion_capsule}
      alt="Orion"
      class="img-orion"
      widths={[400, 800]}
      sizes="50vw"
    />
  </div>

  <div class="layer layer-astronaut" id="layer-astronaut">
    <Image
      src={astronauta}
      alt="Astronauta"
      class="img-astronaut"
      widths={[400, 800]}
      sizes="40vw"
    />
  </div>

  <div class="layer layer-cta" id="layer-cta">
    <div class="cta-content">
      <h2 class="cta-title">Únete a la Misión</h2>
      <p class="cta-desc">Sé parte de la nueva era de exploración espacial</p>
      <a
        href="https://www.nasa.gov/artemis-ii"
        target="_blank"
        rel="noopener"
        class="cta-button"
      >
        <span>Explorar Artemis</span>
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"></path></svg
        >
      </a>
    </div>
  </div>
</div>

<style>
  .closing-section {
    position: relative;
    z-index: 10;
    height: 300vh;
  }

  .closing-visuals {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: 20;
    pointer-events: none;
  }

  .layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    will-change: transform, opacity;
  }

  .layer-moon {
    z-index: 22;
    align-items: flex-end;
  }
  .moon-canvas-container {
    width: 100%;
    height: 100%;
  }

  .layer-orion {
    z-index: 23;
  }
  .img-orion {
    width: clamp(100px, 30vw, 500px);
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 0 30px rgba(177, 177, 177, 0.72));
  }

  .layer-astronaut {
    z-index: 24;
  }
  .img-astronaut {
    width: clamp(100px, 20vw, 300px);
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 0 30px rgba(177, 177, 177, 0.651));
  }

  .layer-cta {
    z-index: 25;
  }
  .layer-cta.is-active {
    pointer-events: auto;
  }

  .layer-badge {
    z-index: 21; /* Detrás de la luna (22) */
    pointer-events: none;
  }

  .cta-content {
    text-align: center;
    font-family: "Poppins", sans-serif;
    color: white;
  }
  .cta-badge {
    display: inline-block;
    font-size: 3.5rem;
    font-weight: 800;
    letter-spacing: 0.8em;
    color: #ffaa33;
    text-shadow: 0 0 20px rgba(255, 170, 51, 0.5);
    margin: 0;
  }
  .cta-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    margin: 15rem 0 0;
    text-shadow: 0 0 40px rgba(82, 154, 255, 0.4);
  }
  .cta-desc {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0 0 2.5rem;
  }
  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.2rem 3rem;
    background: linear-gradient(
      135deg,
      rgba(82, 154, 255, 0.3),
      rgba(130, 190, 255, 0.15)
    );
    border: 1px solid rgba(130, 190, 255, 0.4);
    border-radius: 10px;
    color: white;
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.4s ease;
    backdrop-filter: blur(10px);
  }
  .cta-button:hover {
    background: linear-gradient(
      135deg,
      rgba(82, 154, 255, 0.5),
      rgba(130, 190, 255, 0.3)
    );
    border-color: rgba(130, 190, 255, 0.8);
    box-shadow: 0 0 40px rgba(82, 154, 255, 0.4);
    transform: translateY(-3px);
  }

  @media (max-width: 768px) {
    .cta-badge {
      font-size: 2rem;
      letter-spacing: 0.5em;
    }
    .cta-title {
      font-size: clamp(1.6rem, 8vw, 2.5rem);
      margin: 8rem 0 0;
    }
    .cta-desc {
      font-size: 0.9rem;
      margin: 0 0 1.5rem;
      padding: 0 1rem;
    }
    .cta-button {
      padding: 0.9rem 2rem;
      font-size: 0.9rem;
      gap: 0.5rem;
    }
    .img-orion {
      width: clamp(60px, 25vw, 180px);
    }
    .img-astronaut {
      width: clamp(60px, 18vw, 140px);
    }
  }
</style>

<script>
  import * as THREE from "three";
  import { GLTFLoader } from "three/examples/jsm/loaders/GLTFLoader.js";
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initClosingScene() {
    const trigger = document.getElementById("closing-trigger");
    const earthContainer = document.getElementById("earth-container");

    const orion = document.getElementById("layer-orion");
    const astronaut = document.getElementById("layer-astronaut");
    const cta = document.getElementById("layer-cta");
    const moonContainer = document.getElementById("moon-container");

    if (!trigger || !moonContainer) return;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(
      20,
      moonContainer.clientWidth / moonContainer.clientHeight,
      0.1,
      1000,
    );
    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(moonContainer.clientWidth, moonContainer.clientHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    moonContainer.appendChild(renderer.domElement);

    const ambientLight = new THREE.AmbientLight(0xffffff, 0.2);
    scene.add(ambientLight);

    const dirLight = new THREE.DirectionalLight(0xffffff, 2.5);
    dirLight.position.set(5, 5, 2);
    scene.add(dirLight);

    const fillLight = new THREE.DirectionalLight(0x4488ff, 0.5);
    fillLight.position.set(-5, -2, -5);
    scene.add(fillLight);

    let moonMesh: THREE.Group | undefined;
    let moonProgress = 0;

    function updateMoon() {
      if (!moonMesh) return;
      const startY = -4.5;
      const endY = -1.8;
      moonMesh.position.y = startY + (endY - startY) * moonProgress;
      moonMesh.rotation.x = -0.3 + moonProgress * 0.2;
    }

    const loader = new GLTFLoader();
    loader.load(
      "/the_moon_4k.glb",
      (gltf) => {
        moonMesh = gltf.scene;
        const box = new THREE.Box3().setFromObject(moonMesh);
        const center = box.getCenter(new THREE.Vector3());
        moonMesh.position.x -= center.x;
        moonMesh.position.y -= center.y;
        moonMesh.position.z -= center.z;

        const size = box.getSize(new THREE.Vector3());
        const maxDim = Math.max(size.x, size.y, size.z);
        const scale = 5 / maxDim;
        moonMesh.scale.set(scale, scale, scale);

        scene.add(moonMesh);
        updateMoon();
      },
      undefined,
      (error) => console.error("Error cargando la Luna:", error),
    );

    camera.position.z = 10;

    let isVisible = false;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          isVisible = entry.isIntersecting;
        });
      },
      { threshold: 0 }
    );
    observer.observe(trigger);

    function animate() {
      requestAnimationFrame(animate);
      if (!isVisible) return;

      if (moonMesh) {
        moonMesh.rotation.y += 0.0005;
      }
      renderer.render(scene, camera);
    }
    animate();

    window.addEventListener("resize", () => {
      camera.aspect = moonContainer.clientWidth / moonContainer.clientHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(moonContainer.clientWidth, moonContainer.clientHeight);
    });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: trigger,
        start: "top bottom",
        end: "bottom bottom",
        scrub: 1,
      },
    });

    if (earthContainer) {
      tl.to(earthContainer, { opacity: 0, duration: 0.1 }, 0);
    }

    const moonProxy = { progress: 0 };
    tl.to(
      moonProxy,
      {
        progress: 1,
        duration: 0.6,
        ease: "power2.out",
        onUpdate: () => {
          moonProgress = moonProxy.progress;
          updateMoon();
          if (moonContainer.parentElement) {
            moonContainer.parentElement.style.opacity = `${moonProxy.progress * 2}`;
          }
        },
      },
      0.05,
    );

    if (orion) {
      tl.fromTo(
        orion,
        { opacity: 0, x: "-40vw", y: "15vh", rotate: -15, scale: 0.6 },
        { opacity: 1, x: "-10vw", y: "-5vh", rotate: 0, scale: 0.7, duration: 0.3 },
        0.15,
      );
      tl.to(
        orion, 
        { opacity: 0, x: "20vw", rotate: 20, scale: 0.8, duration: 0.3 }, 
        0.45
      );
    }

    if (astronaut) {
      tl.fromTo(
        astronaut,
        { opacity: 0, x: "30vw", y: "20vh", rotate: 10, scale: 1.0 },
        { opacity: 1, x: "10vw", y: "5vh", rotate: 0, scale: 1.2, duration: 0.3 },
        0.15,
      );
      tl.to(
        astronaut, 
        { opacity: 0, x: "-15vw", rotate: -15, scale: 1.4, duration: 0.3 }, 
        0.45
      );
    }

    if (cta) {
      tl.fromTo(
        cta,
        { opacity: 0, y: 50, scale: 0.95 },
        {
          opacity: 1,
          y: -40,
          scale: 1,
          duration: 0.2,
          onComplete: () => cta.classList.add("is-active"),
          onReverseComplete: () => cta.classList.remove("is-active"),
        },
        0.75,
      );
    }

    const badgeLayer = document.getElementById("layer-badge");
    if (badgeLayer) {
      tl.fromTo(
        badgeLayer,
        { opacity: 0, y: 100, scale: 0.8 },
        { opacity: 1, y: -220, scale: 1, duration: 0.5, ease: "power2.out" },
        0.6
      );
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initClosingScene);
  } else {
    requestAnimationFrame(initClosingScene);
  }
</script>
